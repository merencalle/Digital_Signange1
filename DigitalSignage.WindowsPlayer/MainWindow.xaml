<Window x:Class="DigitalSignage.WindowsPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Digital Signage Player"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Grid Background="Black">
        <Image x:Name="ImageDisplay" Stretch="Uniform" Visibility="Collapsed" />
        <MediaElement x:Name="VideoDisplay" LoadedBehavior="Manual" UnloadedBehavior="Manual"
                      Stretch="Uniform" Visibility="Collapsed"
                      MediaEnded="VideoDisplay_MediaEnded" />
        <TextBlock x:Name="PlaceholderText" Foreground="White" FontSize="36"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center" />
    </Grid>
</Window>
