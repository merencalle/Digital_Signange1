@page
@model DigitalSignage.CMS.Pages.MyPlayer.EditPlaylistModel
@{
    ViewData["Title"] = "Edit My Content";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        @if (Model.Message is not null)
        {
            <div class="alert alert-success"><i class="bi bi-check-circle-fill"></i> @Model.Message</div>
        }
        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage</div>
        }
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Playlist Name</label>
                        <input asp-for="PlaylistName" class="form-control" />
                    </div>
                    <label class="form-label">Content Items</label>
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Name</th>
                                <th>Type</th>
                                <th style="width: 8rem;">Order</th>
                                <th style="width: 10rem;">Duration (sec)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <input type="hidden" asp-for="Rows[i].ContentItemId" />
                                        <input type="hidden" asp-for="Rows[i].ContentItemName" />
                                        <input type="hidden" asp-for="Rows[i].ContentItemType" />
                                        <input class="form-check-input" type="checkbox" asp-for="Rows[i].Selected" />
                                    </td>
                                    <td>@Model.Rows[i].ContentItemName</td>
                                    <td><partial name="_ContentTypeBadge" model="@Model.Rows[i].ContentItemType" /></td>
                                    <td><input type="number" class="form-control form-control-sm" asp-for="Rows[i].Order" /></td>
                                    <td><input type="number" min="1" class="form-control form-control-sm" asp-for="Rows[i].DurationSeconds" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="form-text mb-3">Duration applies to images. Videos always play their full length. Need new content first? Upload it under "Content" in the sidebar.</div>
                    <div class="d-flex gap-2">
                        <button type="submit" asp-page-handler="SaveDraft" class="btn btn-outline-secondary"><i class="bi bi-save"></i> Save Draft</button>
                        <button type="submit" asp-page-handler="Submit" class="btn btn-primary"><i class="bi bi-send"></i> Submit for Approval</button>
                        <a asp-page="Index" class="btn btn-link">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
