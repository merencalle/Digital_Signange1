<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sentinel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <nav class="sidebar d-flex flex-column">
            <a class="sidebar-brand" asp-area="" asp-page="/Index">
                <i class="bi bi-display"></i>
                <span>Sentinel</span>
            </a>
            <ul class="nav flex-column sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path == "/" ? "active" : "")" asp-area="" asp-page="/Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Devices") ? "active" : "")" asp-area="" asp-page="/Devices/Index">
                            <i class="bi bi-hdd-network"></i> Devices
                        </a>
                    </li>
                }
                @if (User.IsInRole("User"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/MyPlayer") ? "active" : "")" asp-area="" asp-page="/MyPlayer/Index">
                            <i class="bi bi-display"></i> My Player
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.StartsWithSegments("/ContentItems") ? "active" : "")" asp-area="" asp-page="/ContentItems/Index">
                        <i class="bi bi-images"></i> Content
                    </a>
                </li>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Playlists") ? "active" : "")" asp-area="" asp-page="/Playlists/Index">
                            <i class="bi bi-collection-play"></i> Playlists
                        </a>
                    </li>
                }
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Approvals") ? "active" : "")" asp-area="" asp-page="/Approvals/Index">
                            <i class="bi bi-clipboard-check"></i> Approvals
                        </a>
                    </li>
                }
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Logs") ? "active" : "")" asp-area="" asp-page="/Logs/Index">
                            <i class="bi bi-journal-text"></i> Logs
                        </a>
                    </li>
                }
                @if (User.IsInRole("SuperAdmin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Wizard") ? "active" : "")" asp-area="" asp-page="/Wizard/Index">
                            <i class="bi bi-magic"></i> Deployment Wizard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Users") ? "active" : "")" asp-area="" asp-page="/Users/Index">
                            <i class="bi bi-people"></i> Users
                        </a>
                    </li>
                }
            </ul>
        </nav>
        <div class="main-area">
            <header class="topbar d-flex align-items-center justify-content-between">
                <h1 class="page-title">@ViewData["Title"]</h1>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-page="/Account/Logout" class="d-flex align-items-center gap-2 mb-0">
                        <span class="text-muted small"><i class="bi bi-person-circle"></i> @User.Identity!.Name</span>
                        <a asp-page="/Account/ChangePassword" class="btn btn-sm btn-outline-secondary"><i class="bi bi-key"></i> Change Password</a>
                        <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-right"></i> Sign Out</button>
                    </form>
                }
            </header>
            <main role="main" class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
