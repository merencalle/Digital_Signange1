@page "{id:int}"
@model DigitalSignage.CMS.Pages.Playlists.EditModel
@{
    ViewData["Title"] = "Edit Playlist";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Playlist.Id" />
                    <input type="hidden" asp-for="Playlist.ScheduleJson" />
                    <div class="mb-3">
                        <label asp-for="Playlist.Name" class="form-label"></label>
                        <input asp-for="Playlist.Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="SelectedContentIds" class="form-label">Content Items</label>
                        <select asp-for="SelectedContentIds" asp-items="Model.ContentItemOptions" class="form-select" multiple size="8"></select>
                        <div class="form-text">Hold Ctrl (Cmd on Mac) to select multiple items.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
