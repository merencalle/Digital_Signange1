@page "{id:int}"
@model DigitalSignage.CMS.Pages.Playlists.EditModel
@{
    ViewData["Title"] = "Edit Playlist";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Playlist.Id" />
                    <div class="mb-3">
                        <label asp-for="Playlist.Name" class="form-label"></label>
                        <input asp-for="Playlist.Name" class="form-control" />
                    </div>

                    <label class="form-label">Content Items</label>
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Name</th>
                                <th>Type</th>
                                <th style="width: 8rem;">Order</th>
                                <th style="width: 10rem;">Duration (sec)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <input type="hidden" asp-for="Rows[i].ContentItemId" />
                                        <input type="hidden" asp-for="Rows[i].ContentItemName" />
                                        <input type="hidden" asp-for="Rows[i].ContentItemType" />
                                        <input class="form-check-input" type="checkbox" asp-for="Rows[i].Selected" />
                                    </td>
                                    <td>@Model.Rows[i].ContentItemName</td>
                                    <td><partial name="_ContentTypeBadge" model="@Model.Rows[i].ContentItemType" /></td>
                                    <td><input type="number" class="form-control form-control-sm" asp-for="Rows[i].Order" /></td>
                                    <td><input type="number" min="1" class="form-control form-control-sm" asp-for="Rows[i].DurationSeconds" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="form-text mb-3">Duration applies to images. Videos always play their full length.</div>

                    <h6 class="mt-4">Schedule (optional)</h6>
                    <div class="form-text mb-2">Leave blank for "always active". Outside this window the screen shows nothing for this playlist.</div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Playlist.StartDate" class="form-label">Start date</label>
                            <input asp-for="Playlist.StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Playlist.EndDate" class="form-label">End date</label>
                            <input asp-for="Playlist.EndDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Playlist.DailyStartTime" class="form-label">Daily start time</label>
                            <input asp-for="Playlist.DailyStartTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Playlist.DailyEndTime" class="form-label">Daily end time</label>
                            <input asp-for="Playlist.DailyEndTime" type="time" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Days of week</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var day in Model.DayOptions)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SelectedDays" value="@day" id="day_@day"
                                           checked="@(Model.SelectedDays.Contains(day))" />
                                    <label class="form-check-label" for="day_@day">@day</label>
                                </div>
                            }
                        </div>
                        <div class="form-text">No days checked means every day.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
