@page "{id:int}"
@model DigitalSignage.CMS.Pages.Playlists.DetailsModel
@{
    ViewData["Title"] = "Playlist Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Playlist.Name</dd>
                </dl>

                <h6 class="mb-2">Content Items</h6>
                @if (Model.Items.Count == 0)
                {
                    <p class="text-muted mb-0">No content items in this playlist yet.</p>
                }
                else
                {
                    <ul class="list-group mb-3">
                    @foreach (var item in Model.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @item.ContentItem.Name
                            <span>
                                <partial name="_ContentTypeBadge" model="@item.ContentItem.ContentType" />
                                <span class="badge text-bg-light border ms-1">@item.DurationSeconds s</span>
                            </span>
                        </li>
                    }
                    </ul>
                }

                @if (Model.Playlist.StartDate is not null || Model.Playlist.EndDate is not null ||
                     Model.Playlist.DaysOfWeek is not null || Model.Playlist.DailyStartTime is not null || Model.Playlist.DailyEndTime is not null)
                {
                    <h6 class="mb-2">Schedule</h6>
                    <ul class="list-unstyled text-muted small mb-0">
                        @if (Model.Playlist.StartDate is not null || Model.Playlist.EndDate is not null)
                        {
                            <li>Active dates: @(Model.Playlist.StartDate?.ToString() ?? "any") &ndash; @(Model.Playlist.EndDate?.ToString() ?? "any")</li>
                        }
                        @if (Model.Playlist.DaysOfWeek is not null)
                        {
                            <li>Days: @Model.Playlist.DaysOfWeek</li>
                        }
                        @if (Model.Playlist.DailyStartTime is not null || Model.Playlist.DailyEndTime is not null)
                        {
                            <li>Daily window: @(Model.Playlist.DailyStartTime?.ToString() ?? "any") &ndash; @(Model.Playlist.DailyEndTime?.ToString() ?? "any")</li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer bg-white d-flex gap-2">
                <a asp-page="Edit" asp-route-id="@Model.Playlist.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
                <a asp-page="Index" class="btn btn-link">Back to list</a>
            </div>
        </div>
    </div>
</div>
