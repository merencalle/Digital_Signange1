@page "{id:int}"
@model DigitalSignage.CMS.Pages.Playlists.DetailsModel
@{
    ViewData["Title"] = "Playlist Details";
}

<h1>Playlist Details</h1>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Playlist.Name</dd>
</dl>

<h2>Content Items</h2>
<ul class="list-group">
@foreach (var item in Model.Items)
{
    <li class="list-group-item">@item.Name (@item.ContentType)</li>
}
</ul>

<p class="mt-3">
    <a asp-page="Edit" asp-route-id="@Model.Playlist.Id" class="btn btn-secondary">Edit</a>
    <a asp-page="Index" class="btn btn-link">Back to list</a>
</p>
