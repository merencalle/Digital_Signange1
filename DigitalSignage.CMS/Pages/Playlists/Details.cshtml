@page "{id:int}"
@model DigitalSignage.CMS.Pages.Playlists.DetailsModel
@{
    ViewData["Title"] = "Playlist Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Playlist.Name</dd>
                </dl>

                <h6 class="mb-2">Content Items</h6>
                @if (Model.Items.Count == 0)
                {
                    <p class="text-muted mb-0">No content items in this playlist yet.</p>
                }
                else
                {
                    <ul class="list-group">
                    @foreach (var item in Model.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @item.Name
                            <partial name="_ContentTypeBadge" model="@item.ContentType" />
                        </li>
                    }
                    </ul>
                }
            </div>
            <div class="card-footer bg-white d-flex gap-2">
                <a asp-page="Edit" asp-route-id="@Model.Playlist.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
                <a asp-page="Index" class="btn btn-link">Back to list</a>
            </div>
        </div>
    </div>
</div>
