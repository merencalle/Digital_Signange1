@page
@model DigitalSignage.CMS.Pages.Playlists.IndexModel
@{
    ViewData["Title"] = "Playlists";
}

<div class="d-flex justify-content-end mb-3">
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Playlist</a>
</div>

<div class="card">
    <div class="card-body p-0">
@if (Model.Playlists.Count == 0)
{
        <p class="text-muted p-3 mb-0">No playlists yet.</p>
}
else
{
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Content Items</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
@foreach (var playlist in Model.Playlists)
{
                <tr>
                    <td>@playlist.Name</td>
                    <td><span class="badge rounded-pill text-bg-light border">@playlist.ContentIds.Count item(s)</span></td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@playlist.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                        <a asp-page="Details" asp-route-id="@playlist.Id" class="btn btn-sm btn-outline-secondary" title="Details"><i class="bi bi-eye"></i></a>
                        <a asp-page="Delete" asp-route-id="@playlist.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
}
            </tbody>
        </table>
}
    </div>
</div>
