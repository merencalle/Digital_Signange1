@page
@model DigitalSignage.CMS.Pages.ContentItems.IndexModel
@{
    ViewData["Title"] = "Content Items";
}

<div class="d-flex justify-content-end mb-3">
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Content</a>
</div>

<div class="card">
    <div class="card-body p-0">
@if (Model.ContentItems.Count == 0)
{
        <p class="text-muted p-3 mb-0">No content items yet.</p>
}
else
{
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>File Path</th>
                    <th>File Size</th>
                    <th>Upload Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model.ContentItems)
{
                <tr>
                    <td>@item.Name</td>
                    <td><partial name="_ContentTypeBadge" model="@item.ContentType" /></td>
                    <td><code>@item.FilePath</code></td>
                    <td>@item.FileSize.ToString("N0") bytes</td>
                    <td>@item.UploadDate</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                        <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details"><i class="bi bi-eye"></i></a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
}
            </tbody>
        </table>
}
    </div>
</div>
