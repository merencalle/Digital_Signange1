@page "{id:int}"
@model DigitalSignage.CMS.Pages.ContentItems.DeleteModel
@{
    ViewData["Title"] = "Delete Content";
}

<h1>Delete Content</h1>

<p>Are you sure you want to delete this content item?</p>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.ContentItem.Name</dd>

    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.ContentItem.ContentType</dd>

    <dt class="col-sm-3">File Path</dt>
    <dd class="col-sm-9">@Model.ContentItem.FilePath</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="ContentItem.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
